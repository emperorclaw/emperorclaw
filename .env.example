# Emperor Claw — environment configuration
# Copy to .env and fill in the required values:  cp .env.example .env
#
# TL;DR for self-hosting: the install.sh / install.ps1 scripts fill in
# everything for you. Only two values MUST be set, and the installer
# GENERATES both automatically:
#   • NEXTAUTH_SECRET          (openssl rand -base64 32)
#   • EMPEROR_CLAW_MASTER_KEY  (openssl rand -hex 32)
# Everything else below has a working default or is optional.
# One value worth setting by hand: EMPEROR_PLATFORM_ADMIN_EMAILS (see below) —
# it unlocks the /ops admin panel and the in-app "Update" button.

# ─── Database safety ───────────────────────────────────────────────────────
# Use ONLY "npm run db:migrate" in production.
# "drizzle-kit push" is DESTRUCTIVE — it can drop columns and data.
# The Docker image runs safe migrations automatically on startup.

# ─── Core (required) ────────────────────────────────────────────────────────
# Postgres connection string. With docker compose this is preconfigured.
POSTGRES_CONNECTION_STRING=postgres://emperor:emperor@localhost:5432/emperor

# Public base URL of the app (used in links, auth callbacks, agent-facing URLs).
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Override the public URL when the app is behind a reverse proxy (optional).
# EMPEROR_PUBLIC_URL=https://claw.mycompany.com

# Session encryption secret for NextAuth. REQUIRED — the app refuses to start
# without it. The installer auto-generates one; to set by hand:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# Port the custom server listens on.
PORT=3000

# ─── Deployment Mode ───────────────────────────────────────────────────────
# "self-hosted" (default): Single company, invite-only team signup, instance admin.
# "cloud": Multi-company SaaS mode, each signup creates a new company.
DEPLOYMENT_MODE=self-hosted

# ─── Storage (choose ONE backend) ───────────────────────────────────────────
# "local" writes artifacts to disk (zero external services — the default for
# self-hosting). "bunny" uses Bunny.net CDN storage.
STORAGE_BACKEND=local

# local backend: directory for stored artifacts (created automatically).
STORAGE_LOCAL_DIR=./.data/storage

# bunny backend (only needed if STORAGE_BACKEND=bunny):
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_ACCESS_KEY=
# Optional: region (e.g. "de"), explicit host, or a public pull-zone base URL.
BUNNY_STORAGE_REGION=
BUNNY_STORAGE_HOST=
BUNNY_STORAGE_PULL_ZONE_URL=

# ─── Secrets encryption ─────────────────────────────────────────────────────
# Master key for encrypting integration secrets at rest (recommended).
# Generate one:  openssl rand -hex 32
EMPEROR_CLAW_MASTER_KEY=

# ─── Email (optional — sending is disabled if unset) ────────────────────────
# If SMTP is not configured, EmperorClaw skips email verification: new accounts
# (including invited teammates) are auto-verified so they can log in immediately.
# Configure SMTP to enable email verification, password resets, and notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Platform admin (recommended for self-hosted) ───────────────────────────
# Comma-separated emails that get access to the /ops platform-admin pages AND
# the in-app "Update" button (self-update is admin-only). Set this to the email
# you'll register your admin account with, e.g. you@yourcompany.com — otherwise
# /ops is unreachable and updates must be applied from the shell (scripts/update.sh).
EMPEROR_PLATFORM_ADMIN_EMAILS=

# ─── Agent tokens (optional) ────────────────────────────────────────────────
# Lifetime in days for company MCP tokens (default 90).
EMPEROR_CLAW_TOKEN_TTL_DAYS=90

# ─── Analytics (optional) ───────────────────────────────────────────────────
# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). Leave unset to ship
# zero analytics — recommended for self-hosted instances.
NEXT_PUBLIC_GA_ID=
